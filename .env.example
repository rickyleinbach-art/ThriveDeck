# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real keys.

# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database — from Supabase Settings > Database > Connection string (URI)
# Use the pooled connection string for DATABASE_URL and the direct one for DIRECT_URL
DATABASE_URL="postgresql://postgres.xxxx:password@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-region.pooler.supabase.com:5432/postgres"
