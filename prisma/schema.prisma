// MetabolicOS — Prisma schema
// Foundation + Weight Loss (Module 2) + Nutrition (Module 3) + Exercise (Module 4)
// + Peptides (Module 5) + Habits & Health Metrics (Module 6).
// Other modules add their own models in later sessions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Extends Supabase auth.users (id references auth.users.id).
// Auth itself is handled by Supabase; this stores app profile data.
model Profile {
  id            String         @id @db.Uuid // = auth.users.id
  email         String         @unique
  fullName      String?        @map("full_name")
  dateOfBirth   DateTime?      @map("date_of_birth") @db.Date
  sex           Sex?
  heightCm      Float?         @map("height_cm")
  timezone      String         @default("UTC")
  unitSystem    UnitSystem     @default(METRIC) @map("unit_system")
  goalWeightKg  Float?         @map("goal_weight_kg")
  activityLevel ActivityLevel? @map("activity_level")
  onboarded     Boolean        @default(false)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("profiles")
}

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY

  @@map("sex")
}

enum UnitSystem {
  METRIC
  IMPERIAL

  @@map("unit_system")
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE

  @@map("activity_level")
}

// =====================================================================
// Weight Loss (Module 2)
// Single flexible body_metrics table covers every tracked series from
// PRD § Weight Loss (weight, body fat, lean mass, and measurements).
// =====================================================================
model BodyMetric {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  metricType MetricType @map("metric_type")
  value      Float
  unit       String
  recordedAt DateTime   @map("recorded_at")
  notes      String?
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([userId, metricType, recordedAt])
  @@map("body_metrics")
}

model ProgressPhoto {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  storagePath String   @map("storage_path")
  takenAt     DateTime @map("taken_at")
  weightKg    Float?   @map("weight_kg")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, takenAt])
  @@map("progress_photos")
}

model Goal {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  metricType  MetricType @map("metric_type")
  targetValue Float      @map("target_value")
  unit        String
  startValue  Float?     @map("start_value")
  targetDate  DateTime?  @map("target_date") @db.Date
  achieved    Boolean    @default(false)
  achievedAt  DateTime?  @map("achieved_at")
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([userId, metricType])
  @@map("goals")
}

enum MetricType {
  WEIGHT
  BODY_FAT
  LEAN_MASS
  WAIST
  CHEST
  ARMS
  LEGS
  NECK
  HIP

  @@map("metric_type")
}

// =====================================================================
// Nutrition (Module 3)
// Core food logging: a per-user food library (manual entries +
// favorites), day-based food logs that snapshot nutrition at log time,
// and one daily macro-target row per user. Barcode / USDA / restaurant
// integrations land in a follow-up session via FoodSource.
// =====================================================================
model FoodItem {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  name        String
  brand       String?
  servingSize Float      @map("serving_size")
  servingUnit String     @map("serving_unit")
  calories    Float
  proteinG    Float      @map("protein_g")
  carbsG      Float      @map("carbs_g")
  fatG        Float      @map("fat_g")
  fiberG      Float?     @map("fiber_g")
  sugarG      Float?     @map("sugar_g")
  sodiumMg    Float?     @map("sodium_mg")
  isFavorite  Boolean    @default(false) @map("is_favorite")
  source      FoodSource @default(MANUAL)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  logs FoodLog[]

  @@index([userId, name])
  @@index([userId, isFavorite])
  @@map("food_items")
}

// One logged eating event. Nutrition values are snapshotted per serving
// at log time so later edits/deletes in the food library never rewrite
// history; foodItemId is only a soft pointer back to the library.
model FoodLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  foodItemId  String?   @map("food_item_id") @db.Uuid
  mealType    MealType  @map("meal_type")
  loggedOn    DateTime  @map("logged_on") @db.Date
  servings    Float     @default(1)
  name        String
  brand       String?
  servingSize Float     @map("serving_size")
  servingUnit String    @map("serving_unit")
  calories    Float
  proteinG    Float     @map("protein_g")
  carbsG      Float     @map("carbs_g")
  fatG        Float     @map("fat_g")
  fiberG      Float?    @map("fiber_g")
  sugarG      Float?    @map("sugar_g")
  sodiumMg    Float?    @map("sodium_mg")
  createdAt   DateTime  @default(now()) @map("created_at")

  foodItem FoodItem? @relation(fields: [foodItemId], references: [id], onDelete: SetNull)

  @@index([userId, loggedOn])
  @@map("food_logs")
}

// Daily macro targets — a single row per user, upserted from the
// macro/protein calculator or manual edits.
model NutritionTarget {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  calories  Float
  proteinG  Float    @map("protein_g")
  carbsG    Float    @map("carbs_g")
  fatG      Float    @map("fat_g")
  fiberG    Float?   @map("fiber_g")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("nutrition_targets")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK

  @@map("meal_type")
}

enum FoodSource {
  MANUAL
  BARCODE
  USDA
  RESTAURANT

  @@map("food_source")
}

// Shared, read-only food catalog seeded from USDA FoodData Central
// (SR Legacy). Nutrition values are per 100 g. Users search it and log
// from it directly, or copy entries into their own food_items library.
model CatalogFood {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fdcId    Int     @unique @map("fdc_id") // USDA FoodData Central id
  name     String
  category String
  calories Float
  proteinG Float   @map("protein_g")
  carbsG   Float   @map("carbs_g")
  fatG     Float   @map("fat_g")
  fiberG   Float?  @map("fiber_g")
  sugarG   Float?  @map("sugar_g")
  sodiumMg Float?  @map("sodium_mg")

  @@index([name])
  @@map("catalog_foods")
}

// =====================================================================
// Exercise (Module 4)
// Exercise library (seeded system rows with null userId + per-user
// custom rows), reusable workout templates (the workout builder), and
// workout sessions with per-set logs. Sets snapshot the exercise name
// and category at log time so library edits never rewrite history.
// =====================================================================
model Exercise {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?          @map("user_id") @db.Uuid // null = shared seed row
  name        String
  category    ExerciseCategory
  muscleGroup MuscleGroup?     @map("muscle_group")
  equipment   String?
  metValue    Float?           @map("met_value") // for calorie estimates
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")

  templateExercises WorkoutTemplateExercise[]
  sets              WorkoutSet[]

  @@index([userId, name])
  @@index([category])
  @@map("exercises")
}

// Templates with userId = null are shared guided programs (seeded,
// tagged with a difficulty); user-built templates have userId set.
model WorkoutTemplate {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid // null = shared guided program
  name       String
  notes      String?
  difficulty Difficulty?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  exercises WorkoutTemplateExercise[]
  workouts  Workout[]

  @@index([userId, name])
  @@map("workout_templates")
}

model WorkoutTemplateExercise {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String? @map("user_id") @db.Uuid // null = row of a shared guided program
  templateId        String  @map("template_id") @db.Uuid
  exerciseId        String  @map("exercise_id") @db.Uuid
  position          Int
  targetSets        Int?    @map("target_sets")
  targetReps        Int?    @map("target_reps")
  targetWeightKg    Float?  @map("target_weight_kg")
  targetDurationMin Float?  @map("target_duration_min")
  restSeconds       Int     @default(90) @map("rest_seconds")

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([templateId, position])
  @@map("workout_template_exercises")
}

// One workout session. A row with completedAt = null is the in-progress
// workout; the workout timer is derived from startedAt, never stored.
model Workout {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  templateId     String?   @map("template_id") @db.Uuid
  name           String
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  durationMin    Float?    @map("duration_min")
  caloriesBurned Float?    @map("calories_burned")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")

  template WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sets     WorkoutSet[]

  @@index([userId, startedAt])
  @@map("workouts")
}

// One logged set (strength: reps + weight; cardio/duration work:
// duration + optional distance). exerciseName/category are snapshots;
// exerciseId is only a soft pointer back to the library.
model WorkoutSet {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  workoutId    String           @map("workout_id") @db.Uuid
  exerciseId   String?          @map("exercise_id") @db.Uuid
  exerciseName String           @map("exercise_name")
  category     ExerciseCategory
  setNumber    Int              @map("set_number")
  reps         Int?
  weightKg     Float?           @map("weight_kg")
  durationMin  Float?           @map("duration_min")
  distanceKm   Float?           @map("distance_km")
  createdAt    DateTime         @default(now()) @map("created_at")

  workout  Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@index([workoutId])
  @@index([userId, exerciseName])
  @@map("workout_sets")
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  HIIT
  WALKING
  RUNNING
  CYCLING
  SWIMMING
  YOGA
  MOBILITY
  STRETCHING
  RECOVERY

  @@map("exercise_category")
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED

  @@map("difficulty")
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  CORE
  FULL_BODY

  @@map("muscle_group")
}

// =====================================================================
// Peptides (Module 5) — SAFETY CRITICAL
// The app only RECORDS what the user's licensed provider prescribed.
// No dose/frequency value in this module is ever computed, defaulted,
// or suggested by the app. See CLAUDE.md § Health & safety rules.
// History rows (injections, side effects, journal) snapshot the
// peptide name and keep only a soft pointer, so deleting a peptide
// never rewrites history.
// =====================================================================
model CareProvider {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  kind      CareProviderKind
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  prescribedPeptides Peptide[] @relation("PeptideProvider")
  suppliedPeptides   Peptide[] @relation("PeptidePharmacy")

  @@index([userId, kind])
  @@map("care_providers")
}

model Peptide {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  name          String
  status        PeptideStatus @default(ACTIVE)
  doseAmount    Float?        @map("dose_amount") // as prescribed, user-entered
  doseUnit      DoseUnit?     @map("dose_unit")
  frequency     String? // free text as the provider phrased it
  startedOn     DateTime?     @map("started_on") @db.Date
  endedOn       DateTime?     @map("ended_on") @db.Date
  lotNumber     String?       @map("lot_number")
  expiresOn     DateTime?     @map("expires_on") @db.Date
  providerId    String?       @map("provider_id") @db.Uuid
  pharmacyId    String?       @map("pharmacy_id") @db.Uuid
  protocolNotes String?       @map("protocol_notes")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  provider       CareProvider?         @relation("PeptideProvider", fields: [providerId], references: [id], onDelete: SetNull)
  pharmacy       CareProvider?         @relation("PeptidePharmacy", fields: [pharmacyId], references: [id], onDelete: SetNull)
  injections     PeptideInjection[]
  reminders      PeptideReminder[]
  sideEffects    PeptideSideEffect[]
  journalEntries PeptideJournalEntry[]

  @@index([userId, status])
  @@map("peptides")
}

// Injection history, including MISSED doses. Dose fields snapshot what
// the user entered at log time.
model PeptideInjection {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  peptideId   String?         @map("peptide_id") @db.Uuid
  peptideName String          @map("peptide_name")
  status      InjectionStatus @default(LOGGED)
  injectedAt  DateTime        @map("injected_at")
  doseAmount  Float?          @map("dose_amount")
  doseUnit    DoseUnit?       @map("dose_unit")
  site        InjectionSite?
  lotNumber   String?         @map("lot_number")
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")

  peptide Peptide? @relation(fields: [peptideId], references: [id], onDelete: SetNull)

  @@index([userId, injectedAt])
  @@index([peptideId])
  @@map("peptide_injections")
}

// Dose / refill / lab / appointment reminders. Marking a repeating
// reminder done advances dueAt by repeatEveryDays; a one-off deactivates.
model PeptideReminder {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  peptideId       String?      @map("peptide_id") @db.Uuid
  kind            ReminderKind
  title           String
  dueAt           DateTime     @map("due_at")
  repeatEveryDays Int?         @map("repeat_every_days")
  active          Boolean      @default(true)
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  peptide Peptide? @relation(fields: [peptideId], references: [id], onDelete: SetNull)

  @@index([userId, active, dueAt])
  @@map("peptide_reminders")
}

model PeptideSideEffect {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  peptideId   String?            @map("peptide_id") @db.Uuid
  peptideName String?            @map("peptide_name")
  occurredAt  DateTime           @map("occurred_at")
  severity    SideEffectSeverity
  description String
  createdAt   DateTime           @default(now()) @map("created_at")

  peptide Peptide? @relation(fields: [peptideId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@map("peptide_side_effects")
}

model PeptideJournalEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  peptideId   String?  @map("peptide_id") @db.Uuid
  peptideName String?  @map("peptide_name")
  entryDate   DateTime @map("entry_date") @db.Date
  content     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  peptide Peptide? @relation(fields: [peptideId], references: [id], onDelete: SetNull)

  @@index([userId, entryDate])
  @@map("peptide_journal_entries")
}

enum CareProviderKind {
  PROVIDER
  PHARMACY

  @@map("care_provider_kind")
}

enum PeptideStatus {
  ACTIVE
  PAUSED
  COMPLETED

  @@map("peptide_status")
}

enum DoseUnit {
  MG
  MCG
  IU
  ML
  UNITS

  @@map("dose_unit")
}

enum InjectionStatus {
  LOGGED
  MISSED

  @@map("injection_status")
}

enum InjectionSite {
  ABDOMEN_LEFT
  ABDOMEN_RIGHT
  THIGH_LEFT
  THIGH_RIGHT
  GLUTE_LEFT
  GLUTE_RIGHT
  ARM_LEFT
  ARM_RIGHT
  OTHER

  @@map("injection_site")
}

enum ReminderKind {
  DOSE
  REFILL
  LAB
  APPOINTMENT

  @@map("reminder_kind")
}

enum SideEffectSeverity {
  MILD
  MODERATE
  SEVERE

  @@map("side_effect_severity")
}

// =====================================================================
// Habits & Health Metrics (Module 6)
// Habits: one flexible model covers checks, quantities, durations, and
// 1–10 ratings; presets for the PRD habit list live in code, not the DB.
// Streaks and scores are always computed from habit_logs, never stored.
// Health metrics: vitals time series, lab results, a record-only
// medication list, and medical history. Medication dose/frequency are
// verbatim user transcriptions — the app never computes or suggests
// them (CLAUDE.md § Health & safety rules). Providers reuse the
// existing care_providers table from Module 5.
// =====================================================================
model Habit {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String
  habitType    HabitType     @default(CUSTOM) @map("habit_type")
  goalType     HabitGoalType @map("goal_type")
  targetValue  Float?        @map("target_value") // required for QUANTITY / DURATION
  unit         String? // "oz", "steps", "min", "hours", …
  scheduleDays Int[]         @default([0, 1, 2, 3, 4, 5, 6]) @map("schedule_days") // 0 = Sun … 6 = Sat
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  logs HabitLog[]

  @@index([userId, active])
  @@map("habits")
}

// One row per habit per day, upserted on (habit_id, logged_on).
// habitName is a snapshot so history survives habit deletion.
// value: 1 for a plain check, the measured amount for quantity/duration,
// or the 1–10 score for ratings.
model HabitLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  habitId   String?  @map("habit_id") @db.Uuid
  habitName String   @map("habit_name")
  loggedOn  DateTime @map("logged_on") @db.Date
  value     Float    @default(1)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  habit Habit? @relation(fields: [habitId], references: [id], onDelete: SetNull)

  @@unique([habitId, loggedOn])
  @@index([userId, loggedOn])
  @@map("habit_logs")
}

// Vitals time series. Blood pressure uses value = systolic and
// secondaryValue = diastolic; every other kind uses value alone.
model HealthMetric {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  kind           HealthMetricKind
  value          Float
  secondaryValue Float?           @map("secondary_value")
  unit           String
  measuredAt     DateTime         @map("measured_at")
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([userId, kind, measuredAt])
  @@map("health_metrics")
}

// Lab results (A1C, lipids, testosterone, vitamin D, and anything else).
// testName is free text; common panels are offered as presets in code.
model LabResult {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  testName      String   @map("test_name")
  value         Float
  unit          String
  referenceLow  Float?   @map("reference_low")
  referenceHigh Float?   @map("reference_high")
  collectedOn   DateTime @map("collected_on") @db.Date
  labName       String?  @map("lab_name")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, testName, collectedOn])
  @@map("lab_results")
}

// Record-only medication list. doseText / frequency are transcriptions
// of the user's own prescription label, never generated by the app.
model Medication {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String
  doseText   String?   @map("dose_text")
  frequency  String? // free text as the provider phrased it
  reason     String?
  prescriber String? // free text; full provider records live in care_providers
  startedOn  DateTime? @map("started_on") @db.Date
  endedOn    DateTime? @map("ended_on") @db.Date
  active     Boolean   @default(true)
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId, active])
  @@map("medications")
}

model MedicalCondition {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  name        String
  status      ConditionStatus @default(ACTIVE)
  diagnosedOn DateTime?       @map("diagnosed_on") @db.Date
  resolvedOn  DateTime?       @map("resolved_on") @db.Date
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("medical_conditions")
}

enum HabitType {
  SLEEP
  WATER
  MEDITATION
  READING
  STRETCHING
  PROTEIN
  FIBER
  SUPPLEMENTS
  STEPS
  WALK
  ROUTINE
  SUNLIGHT
  MOOD
  ENERGY
  STRESS
  CUSTOM

  @@map("habit_type")
}

enum HabitGoalType {
  CHECK
  QUANTITY
  DURATION
  RATING

  @@map("habit_goal_type")
}

enum HealthMetricKind {
  BLOOD_PRESSURE
  HEART_RATE
  RESTING_HEART_RATE
  HRV
  BLOOD_GLUCOSE

  @@map("health_metric_kind")
}

enum ConditionStatus {
  ACTIVE
  MANAGED
  RESOLVED

  @@map("condition_status")
}

// =====================================================================
// Community (Module 9)
// The app's first shared, multi-user data (PRD § Community). Every
// signed-in user can read posts/comments; writes are author-scoped via
// RLS (see prisma/migrations/0009_community.sql). authorName is a
// write-time snapshot so we never read another user's profile, and is
// null for anonymous content. like_count / comment_count are
// trigger-maintained counters. Groups, friends, DMs, polls, and events
// are deferred to a later session.
// =====================================================================
model CommunityPost {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  authorName   String?  @map("author_name")
  category     CommunityCategory
  title        String
  body         String
  imagePath    String?  @map("image_path")
  isAnonymous  Boolean  @default(false) @map("is_anonymous")
  isPinned     Boolean  @default(false) @map("is_pinned")
  isFlagged    Boolean  @default(false) @map("is_flagged")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  comments     CommunityComment[]
  likes        CommunityPostLike[]
  saves        CommunitySave[]

  @@index([category, createdAt])
  @@index([createdAt])
  @@index([userId])
  @@map("community_posts")
}

model CommunityComment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId      String   @map("post_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  authorName  String?  @map("author_name")
  body        String
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  isFlagged   Boolean  @default(false) @map("is_flagged")
  likeCount   Int      @default(0) @map("like_count")
  createdAt   DateTime @default(now()) @map("created_at")

  post        CommunityPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes       CommunityCommentLike[]

  @@index([postId, createdAt])
  @@map("community_comments")
}

model CommunityPostLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("community_post_likes")
}

model CommunityCommentLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("community_comment_likes")
}

model CommunitySave {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("community_saves")
}

enum CommunityCategory {
  WEIGHT_LOSS
  NUTRITION
  FITNESS
  RECIPES
  WALKING_CLUB
  STRENGTH
  CARDIO
  PEPTIDE_EXPERIENCES
  LIFESTYLE
  SUCCESS_STORIES
  PROGRESS_PICS
  MOTIVATION
  MEAL_PREP
  QUESTIONS
  GENERAL

  @@map("community_category")
}

// =====================================================================
// Challenges & Gamification (Module 10)
// Challenge definitions live in code (src/lib/challenges/catalog.ts); this
// table only records participation + a progress snapshot used for shared
// leaderboards (shared-read RLS, author-scoped writes). progressValue /
// progressPct are recomputed from the user's own logged data. Gamification
// (XP, levels, badges, streaks) is derived at read time and stores nothing.
// =====================================================================
model ChallengeParticipant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  displayName   String    @map("display_name")
  challengeKey  String    @map("challenge_key")
  startDate     DateTime  @map("start_date") @db.Date
  progressValue Float     @default(0) @map("progress_value")
  progressPct   Int       @default(0) @map("progress_pct")
  completed     Boolean   @default(false)
  completedAt   DateTime? @map("completed_at")
  joinedAt      DateTime  @default(now()) @map("joined_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([userId, challengeKey])
  @@index([challengeKey, progressPct])
  @@map("challenge_participants")
}
